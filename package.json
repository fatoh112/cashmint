{
  "name": "cashmint",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:all",
    "build:all": "node scripts/generate-mode-icons.mjs && npm run build:master && npm run build:pos && npm run build:store",
    "build:master": "node scripts/generate-mode-icons.mjs && vite build --mode master",
    "build:pos": "node scripts/generate-mode-icons.mjs && vite build --mode pos",
    "build:store": "node scripts/generate-mode-icons.mjs && vite build --mode store",
    "lint": "oxlint src",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.6",
    "fast-average-color": "^9.5.2",
    "lucide-react": "^1.24.0",
    "papaparse": "^5.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "supabase": "^2.109.1",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.0"
  }
}
